# Dev (SQLite - no external deps needed):
DATABASE_URL=sqlite+aiosqlite:///./data/aitutor.db
DISABLE_REDIS=True

# Prod (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://aitutor:aitutor@localhost:5432/aitutor
# REDIS_URL=redis://localhost:6379/0

SECRET_KEY=change-me-in-production

# AI / LLM provider. Switch between openai / deepseek / minimax / custom.
LLM_PROVIDER=minimax
OPENAI_API_KEY=sk-placeholder
MINIMAX_API_KEY=

ENVIRONMENT=development
SENTRY_DSN=
CORS_ORIGINS=["http://localhost:3000"]
