# Git LFS - Track large binary files
# Animation resources
backend/static/animations/*.mp4 filter=lfs diff=lfs merge=lfs -text
backend/static/animations/*.mp3 filter=lfs diff=lfs merge=lfs -text
backend/static/animations/*.py filter=lfs diff=lfs merge=lfs -text

# Audio resources (for future files - existing files remain in regular git)
backend/static/audio/**/*.mp3 filter=lfs diff=lfs merge=lfs -text
