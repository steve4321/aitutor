# AI Tutor - Environment Variables
# Copy this file to .env and fill in the values
# Override defaults in docker-compose.yml via this file

# PostgreSQL
POSTGRES_USER=aitutor
POSTGRES_PASSWORD=aitutor
POSTGRES_DB=aitutor

# Backend
DATABASE_URL=postgresql+asyncpg://aitutor:aitutor@postgres:5432/aitutor
REDIS_URL=redis://redis:6379/0

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Auth
SECRET_KEY=change-me-to-a-random-string-in-production

# AI / LLM
OPENAI_API_KEY=sk-your-key-here

# App
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:3000"]